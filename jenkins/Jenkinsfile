pipeline {
    agent any

    environment {
        APP_NAME   = 'cicd-demo-app'
        VERSION    = "1.0.${BUILD_NUMBER}"
        BUILD_ENV  = 'staging'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ──────────────────────────────────
        stage('Checkout') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Checkout Source Code     ║"
                echo "╚══════════════════════════════════╝"
                checkout scm
                echo "Build #${BUILD_NUMBER} | Version: ${VERSION}"
            }
        }

        // ──────────────────────────────────
        stage('Build Website') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Build & Optimize CSS     ║"
                echo "╚══════════════════════════════════╝"
                echo "Processing website/style.css..."
                sh 'ls -la website/'
                sleep(5)
                echo "✅ Website assets optimized!"
            }
        }

        // ──────────────────────────────────
        stage('Lint & Validation') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: HTML/CSS Linting         ║"
                echo "╚══════════════════════════════════╝"
                echo "Working on website/index.html..."
                sleep(4)
                echo "  ✓ HTML Structure           [PASS]"
                echo "  ✓ CSS Syntax               [PASS]"
                echo "  ✓ Accessibility Check      [PASS]"
                echo "✅ Quality gate: PASSED"
            }
        }

        // ──────────────────────────────────
        stage('Deploy to Staging') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Deploy to Staging        ║"
                echo "╚══════════════════════════════════╝"
                echo "Deploying website assets to mock staging server..."
                sleep(5)
                echo "  ✓ Syncing files to /var/www/html/staging"
                echo "  ✓ Restarting Nginx"
                echo "✅ Deployed successfully!"
                echo "🌐 Internal URL: http://staging.app.local"
            }
        }
    }

    post {
        success {
            echo "══════════════════════════════════════"
            echo "🎉 PIPELINE SUCCESS!"
            echo "   App     : ${APP_NAME}"
            echo "   Version : ${VERSION}"
            echo "   Build # : ${BUILD_NUMBER}"
            echo "   Env     : ${BUILD_ENV}"
            echo "══════════════════════════════════════"
        }
        failure {
            echo "══════════════════════════════════════"
            echo "❌ PIPELINE FAILED!"
            echo "   Build #${BUILD_NUMBER} failed."
            echo "   Check logs for details."
            echo "══════════════════════════════════════"
        }
        always {
            echo "📊 Pipeline finished. Metrics pushed to Prometheus."
            echo "📈 View dashboard: http://localhost:3000"
        }
    }
}
