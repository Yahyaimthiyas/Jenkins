pipeline {
    agent any

    environment {
        APP_NAME   = 'cicd-demo-app'
        VERSION    = "1.0.${BUILD_NUMBER}"
        BUILD_ENV  = 'staging'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ──────────────────────────────────
        stage('Checkout') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Checkout Source Code     ║"
                echo "╚══════════════════════════════════╝"
                echo "Cloning branch: ${env.BRANCH_NAME ?: 'main'}"
                echo "Build #${BUILD_NUMBER} | Version: ${VERSION}"
                sleep(2)
            }
        }

        // ──────────────────────────────────
        stage('Build') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Build                    ║"
                echo "╚══════════════════════════════════╝"
                echo "Building ${APP_NAME} v${VERSION}..."
                echo "Compiling source code..."
                sleep(5)
                echo "✅ Build completed successfully!"
            }
        }

        // ──────────────────────────────────
        stage('Unit Tests') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Unit Tests               ║"
                echo "╚══════════════════════════════════╝"
                echo "Running unit test suite..."
                sleep(4)
                echo "  ✓ AuthService tests        [PASS]"
                echo "  ✓ UserController tests     [PASS]"
                echo "  ✓ DataProcessor tests      [PASS]"
                echo "  ✓ Config Validation tests  [PASS]"
                echo "✅ All tests passed! Coverage: 87%"
            }
        }

        // ──────────────────────────────────
        stage('Code Quality') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Code Quality Analysis    ║"
                echo "╚══════════════════════════════════╝"
                echo "Running static analysis..."
                sleep(3)
                echo "  ✓ No critical vulnerabilities found"
                echo "  ✓ Code style: Compliant"
                echo "  ✓ Complexity score: 4.2 (Good)"
                echo "✅ Quality gate: PASSED"
            }
        }

        // ──────────────────────────────────
        stage('Docker Build') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Docker Build & Package   ║"
                echo "╚══════════════════════════════════╝"
                echo "Building Docker image: ${APP_NAME}:${VERSION}"
                sleep(5)
                echo "  Layer 1: Base OS          [OK]"
                echo "  Layer 2: Dependencies     [OK]"
                echo "  Layer 3: App code         [OK]"
                echo "  Layer 4: Config           [OK]"
                echo "✅ Image built: ${APP_NAME}:${VERSION}"
            }
        }

        // ──────────────────────────────────
        stage('Integration Tests') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Integration Tests        ║"
                echo "╚══════════════════════════════════╝"
                echo "Running integration test suite..."
                sleep(6)
                echo "  ✓ API endpoint /health     [200 OK]"
                echo "  ✓ API endpoint /users      [200 OK]"
                echo "  ✓ Database connectivity    [PASS]"
                echo "  ✓ Auth flow end-to-end     [PASS]"
                echo "✅ Integration tests passed!"
            }
        }

        // ──────────────────────────────────
        stage('Deploy') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Deploy to Staging        ║"
                echo "╚══════════════════════════════════╝"
                echo "Deploying ${APP_NAME} v${VERSION} → ${BUILD_ENV}..."
                sleep(5)
                echo "  ✓ Pulling image from registry"
                echo "  ✓ Stopping old container"
                echo "  ✓ Starting new container"
                echo "  ✓ Health check passed"
                echo "✅ Deployed successfully to ${BUILD_ENV}!"
                echo "🌐 App URL: http://staging.${APP_NAME}.local"
            }
        }

        // ──────────────────────────────────
        stage('Smoke Test') {
            steps {
                echo "╔══════════════════════════════════╗"
                echo "║  Stage: Smoke Tests (Post-Deploy)║"
                echo "╚══════════════════════════════════╝"
                echo "Running post-deployment smoke tests..."
                sleep(3)
                echo "  ✓ Homepage loads correctly"
                echo "  ✓ Login flow works"
                echo "  ✓ API responds correctly"
                echo "✅ Smoke tests passed! Deployment verified."
            }
        }
    }

    post {
        success {
            echo "══════════════════════════════════════"
            echo "🎉 PIPELINE SUCCESS!"
            echo "   App     : ${APP_NAME}"
            echo "   Version : ${VERSION}"
            echo "   Build # : ${BUILD_NUMBER}"
            echo "   Env     : ${BUILD_ENV}"
            echo "══════════════════════════════════════"
        }
        failure {
            echo "══════════════════════════════════════"
            echo "❌ PIPELINE FAILED!"
            echo "   Build #${BUILD_NUMBER} failed."
            echo "   Check logs for details."
            echo "══════════════════════════════════════"
        }
        always {
            echo "📊 Pipeline finished. Metrics pushed to Prometheus."
            echo "📈 View dashboard: http://localhost:3000"
        }
    }
}
